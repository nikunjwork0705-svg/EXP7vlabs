{
  "experimentName": "Study and Measurement of the Power Factor of an Electrical Load",
  "defaultLocale": "en",
  "locales": [
    "en"
  ],
  "audio": {
    "autoplay": false
  },
  "steps": [
    {
      "id": 1,
      "target": "#experiment-title-board",
      "title": {
        "en": "Experiment Goal"
      },
      "description": {
        "en": "This board states the lab's objective. The walkthrough follows the same order students use to find Power Factor of various Electrical Loads."
      },
      "audio": "#",
      "placement": "bottom"
    },
    {
      "id": 2,
      "target": "#action-buttons-panel",
      "title": {
        "en": "Lab Actions"
      },
      "description": {
        "en": "Use these controls to check wiring, record readings, reset the setup, print results, auto-connect the circuit, take an AI-Guide or to calculate the Power Factor."
      },
      "audio": "#",
      "placement": "right"
    },
    {
      "id": 3,
      "target": "#instruction-button",
      "title": {
        "en": "Instructions Button"
      },
      "description": {
        "en": "Click here to read the intructions manual for performing the experiment."
      },
      "audio": "#",
      "placement": "right"
    },
    {
      "id": 4,
      "target": "#ai-guide-button",
      "title": {
        "en": "AI Guide Button"
      },
      "description": {
        "en": ""
      },
      "audio": "#",
      "placement": "right"
    },
    {
      "id": 5,
      "target": "#check-button",
      "title": {
        "en": "Check Button"
      },
      "description": {
        "en": "Click this to verify the wiring is correct before turning on the power."
      },
      "audio": "#",
      "placement": "right"
    },
    {
      "id": 6,
      "target": "#auto-connect-button",
      "title": {
        "en": "Auto Connect Button"
      },
      "description": {
        "en": "This button will automatically wire the circuit for the selected load."
      },
      "audio": "#",
      "placement": "right"
    },
    {
      "id": 7,
      "target": "#add-button",
      "title": {
        "en": "Add Button"
      },
      "description": {
        "en": "Records the current meter readings directly into the Observation Table."
      },
      "audio": "#",
      "placement": "right"
    },
    {
      "id": 8,
      "target": "#reset-button",
      "title": {
        "en": "Reset Button"
      },
      "description": {
        "en": "Clears all wires, turns off all power, and resets the simulation to its default state."
      },
      "audio": "#",
      "placement": "right"
    },
    {
      "id": 9,
      "target": "#print-button",
      "title": {
        "en": "Print Button"
      },
      "description": {
        "en": "Prints the whole page."
      },
      "audio": "#",
      "placement": "right"
    },
    {
      "id": 10,
      "target": "#control-panel",
      "title": {
        "en": "Formulas Panel"
      },
      "description": {
        "en": "To Calculate the Power Factor use the formula given in this Panel."
      },
      "audio": "#",
      "placement": "right"
    },
    {
      "id": 11,
      "target": "#mcb-supply",
      "title": {
        "en": "MCB"
      },
      "description": {
        "en": "The main power switch. Turn this on only after your circuit passes the CHECK step."
      },
      "audio": "#",
      "placement": "bottom"
    },
    {
      "id": 12,
      "target": "#ac-voltage-v",
      "title": {
        "en": "Voltmeter"
      },
      "description": {
        "en": "Displays the active AC voltage currently being supplied to the circuit."
      },
      "audio": "#",
      "placement": "bottom"
    },
    {
      "id": 13,
      "target": "#ac-current-a1",
      "title": {
        "en": "Ammeter A1"
      },
      "description": {
        "en": "Measures the total main current being drawn by the entire parallel circuit."
      },
      "audio": "#",
      "placement": "bottom"
    },
    {
      "id": 14,
      "target": "#ac-wattmeter-w",
      "title": {
        "en": "Wattmeter"
      },
      "description": {
        "en": "Measures the true power consumed by the circuit."
      },
      "audio": "#",
      "placement": "bottom"
    },
    {
      "id": 15,
      "target": "#ac-current-a2",
      "title": {
        "en": "Ammeter A2"
      },
      "description": {
        "en": "Measures the branch current flowing specifically through the Resistor."
      },
      "audio": "#",
      "placement": "bottom"
    },
    {
      "id": 16,
      "target": "#ac-current-a3",
      "title": {
        "en": "Ammeter A3"
      },
      "description": {
        "en": "Measures the branch current flowing specifically through the Inductor."
      },
      "audio": "#",
      "placement": "left"
    },
    {
      "id": 17,
      "target": "#ac-current-a4",
      "title": {
        "en": "Ammeter A4"
      },
      "description": {
        "en": "Measures the branch current flowing specifically through the Capacitor."
      },
      "audio": "#",
      "placement": "left"
    },
    {
      "id": 18,
      "target": "#variac-button",
      "title": {
        "en": "Autotransformer"
      },
      "description": {
        "en": "An autotransformer used to safely step the voltage up for the experiment."
      },
      "audio": "#",
      "placement": "top"
    },
    {
      "id": 19,
      "target": "#resistor-component",
      "title": {
        "en": "Resistor"
      },
      "description": {
        "en": "The purely resistive component of the parallel RLC circuit."
      },
      "audio": "#",
      "placement": "top"
    },
    {
      "id": 20,
      "target": "#capacitor-component",
      "title": {
        "en": "Capacitor"
      },
      "description": {
        "en": "The capacitive component of the parallel RLC circuit."
      },
      "audio": "#",
      "placement": "top"
    },
    {
      "id": 21,
      "target": "#inductor-component",
      "title": {
        "en": "Inductor"
      },
      "description": {
        "en": "The inductive component of the parallel RLC circuit."
      },
      "audio": "#",
      "placement": "top"
    },
    {
      "id": 22,
      "target": "#observation-table-panel",
      "title": {
        "en": "Observation Table"
      },
      "description": {
        "en": "Each added reading appears in this table. Record your readings to calculate the power factor."
      },
      "audio": "#",
      "placement": "left" 
    },
    {
      "id": 23,
      "target": "#generate-report-button",
      "title": {
        "en": "Generate Report"
      },
      "description": {
        "en": "Click this once you have recorded enough readings to generate a final report of your experiment."
      },
      "audio": "#",
      "placement": "top"
    },
    {
      "id": 24,
      "target": "#calculations-board",
      "title": {
        "en": "Theoretical Calculations"
      },
      "description": {
        "en": "Use this board to manually calculate the theoretical values based on formulas and verify them against your readings."
      },
      "audio": "#",
      "placement": "top"
    }
  ]
}