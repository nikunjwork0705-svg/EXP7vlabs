{
  "experimentName": "Study and Measurement of the Power Factor of an Electrical Load",
  "defaultLocale": "en",
  "locales": [
    "en"
  ],
  "audio": {
    "autoplay": false
  },
  "steps": [
    {
      "id": 1,
      "target": "#experiment-title-board",
      "title": { "en": "Experiment Goal" },
      "description": { "en": "This board states the lab's objective. The walkthrough follows the same order students use to find Power Factor of various Electrical Loads." },
      "audio": "#",
      "placement": "bottom"
    },
    {
      "id": 2,
      "target": "#instruction-button",
      "title": { "en": "Instructions Button" },
      "description": { "en": "Click here to read the intructions manual for performing the experiment." },
      "audio": "#",
      "placement": "right"
    },
    {
      "id": 3,
      "target": "#ai-guide-button",
      "title": { "en": "AI Guide Button" },
      "description": { "en": "" },
      "audio": "#",
      "placement": "right"
    },
    {
      "id": 4,
      "target": "#check-button",
      "title": { "en": "Check Button" },
      "description": { "en": "Click this to verify the wiring is correct before turning on the power." },
      "audio": "#",
      "placement": "right"
    },
    {
      "id": 5,
      "target": "#auto-connect-button",
      "title": { "en": "Auto Connect Button" },
      "description": { "en": "This button will automatically wire the circuit for the selected load." },
      "audio": "#",
      "placement": "right"
    },
    {
      "id": 6,
      "target": "#add-button",
      "title": { "en": "Add Button" },
      "description": { "en": "Records the current meter readings directly into the Observation Table." },
      "audio": "#",
      "placement": "right"
    },
    {
      "id": 7,
      "target": "#reset-button",
      "title": { "en": "Reset Button" },
      "description": { "en": "Clears all wires, turns off all power, and resets the simulation to its default state." },
      "audio": "#",
      "placement": "right"
    },
    {
      "id": 8,
      "target": "#print-button",
      "title": { "en": "Print Button" },
      "description": { "en": "Prints the whole page." },
      "audio": "#",
      "placement": "right"
    },
    {
      "id": 9,
      "target": "#control-panel",
      "title": { "en": "Formulas Panel" },
      "description": { "en": "To Calculate the Power Factor use the formula given in this Panel." },
      "audio": "#",
      "placement": "right"
    },
    {
      "id": 10,
      "target": "#mcb-walkthrough-target",
      "title": { "en": "MCB" },
      "description": { "en": "The main power switch. Turn this on only after your circuit passes the CHECK step." },
      "audio": "#",
      "placement": "bottom"
    },
    {
      "id": 11,
      "target": "#voltmeter-walkthrough-target",
      "title": { "en": "Voltmeter" },
      "description": { "en": "Displays the active AC voltage currently being supplied to the circuit." },
      "audio": "#",
      "placement": "bottom"
    },
   {
      "id": 12,
      "target": "#ammeter-a1-walkthrough-target",
      "title": { "en": "Ammeter A1" },
      "description": { "en": "Measures the total main current being drawn by the entire parallel circuit." },
      "audio": "#",
      "placement": "bottom"
    },
    {
      "id": 13,
      "target": "#wattmeter-walkthrough-target",
      "title": { "en": "Wattmeter" },
      "description": { "en": "Measures the true power consumed by the circuit." },
      "audio": "#",
      "placement": "bottom"
    },
    {
      "id": 14,
      "target": "#ammeter-a2-walkthrough-target",
      "title": { "en": "Ammeter A2" },
      "description": { "en": "Measures the branch current flowing specifically through the Resistor." },
      "audio": "#",
      "placement": "bottom"
    },
    {
      "id": 15,
      "target": "#ammeter-a3-walkthrough-target",
      "title": { "en": "Ammeter A3" },
      "description": { "en": "Measures the branch current flowing specifically through the Inductor." },
      "audio": "#",
      "placement": "left"
    },
    {
      "id": 16,
      "target": "#ammeter-a4-walkthrough-target",
      "title": { "en": "Ammeter A4" },
      "description": { "en": "Measures the branch current flowing specifically through the Capacitor." },
      "audio": "#",
      "placement": "left"
    },
    {
      "id": 17,
      "target": "#variac-walkthrough-target",
      "title": { "en": "Autotransformer" },
      "description": { "en": "An autotransformer used to safely step the voltage up for the experiment." },
      "audio": "#",
      "placement": "top"
    },
    {
      "id": 18,
      "target": "#resistor-walkthrough-target",
      "title": { "en": "Resistor" },
      "description": { "en": "The purely resistive component of the parallel RLC circuit." },
      "audio": "#",
      "placement": "bottom"
    },
    {
      "id": 19,
      "target": "#capacitor-walkthrough-target",
      "title": { "en": "Capacitor" },
      "description": { "en": "The capacitive component of the parallel RLC circuit." },
      "audio": "#",
      "placement": "bottom"
    },
    {
      "id": 20,
      "target": "#inductor-walkthrough-target",
      "title": { "en": "Inductor" },
      "description": { "en": "The inductive component of the parallel RLC circuit." },
      "audio": "#",
      "placement": "bottom"
    },
    {
      "id": 21,
      "target": "#observation-table-panel",
      "title": { "en": "Observation Table" },
      "description": { "en": "Each added reading appears in this table. Record your readings to calculate the power factor." },
      "audio": "#",
      "placement": "left"
    },
    {
      "id": 22,
      "target": "#calculations-board",
      "title": { "en": "Theoretical Calculations" },
      "description": { "en": "Use this board to manually calculate the theoretical values based on formulas and verify them against your readings." },
      "audio": "#",
      "placement": "top"
    },
    {
      "id": 23,
      "target": "#generate-report-button",
      "title": { "en": "Generate Report" },
      "description": { "en": "Click this once you have recorded enough readings to generate a final report of your experiment." },
      "audio": "#",
      "placement": "top"
    }
  ]
}